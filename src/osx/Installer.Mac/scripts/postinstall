#!/bin/bash
set -e

PACKAGE=$1
INSTALL_DESTINATION=$2

function IsBrewPkgInstalled
{
    # Check if Homebrew is installed
    /usr/bin/which brew > /dev/null
    if [ $? -eq 0 ]
    then
        # Check if the package has been installed
        brew ls --versions "$1" > /dev/null
        if [ $? -eq 0 ]
        then
            return 0
        fi
    fi
    return 1
}

# Check if Java GCM is present on this system and unlink it should it exist
if [ -L /usr/local/bin/git-credential-manager ] && IsBrewPkgInstalled "git-credential-manager";
then
    brew unlink git-credential-manager
fi

# Create symlink to GCM in /usr/local/bin
mkdir -p /usr/local/bin
/bin/ln -Fs "$INSTALL_DESTINATION/git-credential-manager" /usr/local/bin/git-credential-manager

# Determine the actual end-user to configure GCM for. When the installer is
# invoked by a service account (e.g. an MDM or fleet-management tool such as
# Workbrew), $USER refers to the service account rather than the logged-in
# console user. Querying SystemConfiguration via scutil gives us the user
# currently owning the console session, which is the user whose ~/.gitconfig
# we want to update. Fall back to $USER if no console user can be determined
# (e.g. nobody is logged in, or the value is "loginwindow"/"root").
CONSOLE_USER=$(echo "show State:/Users/ConsoleUser" | scutil | awk '/Name :/ { print $3 }')
# Validate the value before using it: it must be a non-empty, well-formed
# username (alphanumeric, underscore, hyphen, dot) and not a placeholder such
# as "loginwindow" or the root account. Otherwise fall back to $USER.
if ! [[ "$CONSOLE_USER" =~ ^[a-zA-Z_][a-zA-Z0-9_.-]*$ ]] \
    || [ "$CONSOLE_USER" = "loginwindow" ] \
    || [ "$CONSOLE_USER" = "root" ] \
    || ! /usr/bin/id -u "$CONSOLE_USER" > /dev/null 2>&1; then
    CONSOLE_USER=$USER
fi

# Configure GCM for the current user (running as the current user to avoid root
# from taking ownership of ~/.gitconfig)
sudo -u "$CONSOLE_USER" "$INSTALL_DESTINATION/git-credential-manager" configure

exit 0
